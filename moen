local function CreateRainbowFrame(frame, thickness, speed)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Thickness = thickness or 3
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    
    local hue = 0
    task.spawn(function()
        while frame and frame.Parent do
            hue = (hue + (speed or 0.003)) % 1
            stroke.Color = Color3.fromHSV(hue, 1, 1)
            task.wait(0.05)
        end
    end)
    return stroke
end

local function CreateRainbowBackground(frame, speed)
    task.spawn(function()
        local hue = 0
        while frame and frame.Parent do
            hue = (hue + (speed or 0.002)) % 1
            frame.BackgroundColor3 = Color3.fromHSV(hue, 0.8, 0.2)
            task.wait(0.05)
        end
    end)
end

