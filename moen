local function SetupPlayerTracking()
    Players.PlayerRemoving:Connect(function(player)
        if TargetInput and TargetInput.Text == player.Name then
            TargetInput.Text = ""
            local notif = Instance.new("TextLabel", ScreenGui)
            notif.Size = UDim2.new(0, math.min(getScreenWidth() * 0.25, 280), 0, math.min(getScreenHeight() * 0.04, 35))
            notif.Position = UDim2.new(0.5, -140, 0.8, 0)
            notif.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
            notif.Text = "⚠️ " .. player.Name .. " خرج من السيرفر - تم مسح الهدف"
            notif.TextColor3 = Colors.White
            notif.TextSize = math.max(9, math.min(13, getScreenWidth() * 0.012))
            Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)
            game:GetService("Debris"):AddItem(notif, 3)
        end
    end)
    
    local playersList = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= plr then
            table.insert(playersList, player.Name)
        end
    end
    
    for i, playerName in ipairs(playersList) do
        task.wait(0.8)
        ShowPlayerNotification(playerName, true)
    end
    
    Players.PlayerAdded:Connect(function(player)
        if player ~= plr then
            ShowPlayerNotification(player.Name, true)
        end
    end)
    
    Players.PlayerRemoving:Connect(function(player)
        ShowPlayerNotification(player.Name, false)
    end)
end

SetupPlayerTracking()

