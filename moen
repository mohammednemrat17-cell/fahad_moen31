local function ToggleBodyExtension()
    local character = plr.Character
    if not character then 
        local notif = Instance.new("TextLabel", ScreenGui)
        notif.Size = UDim2.new(0, math.min(getScreenWidth() * 0.25, 280), 0, math.min(getScreenHeight() * 0.04, 35))
        notif.Position = UDim2.new(0.5, -140, 0.8, 0)
        notif.BackgroundColor3 = Colors.NeonOrange
        notif.Text = "⚠️ انتظر حتى تظهر شخصيتك"
        notif.TextColor3 = Colors.Dark
        notif.TextSize = math.max(9, math.min(13, getScreenWidth() * 0.012))
        Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)
        game:GetService("Debris"):AddItem(notif, 2)
        return 
    end
    
    if not isSkyboxEnabled then
        isSkyboxEnabled = true
        
        local humanoid = character:FindFirstChild("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    local originalSize = part.Size
                    part.Size = originalSize * 1.3
                    table.insert(bodyParts, {part = part, originalSize = originalSize})
                end
            end
            
            local effect = Instance.new("ParticleEmitter", rootPart)
            effect.Texture = "rbxasset://textures/particles/sparkles_main.dds"
            effect.Rate = 50
            effect.Lifetime = NumberRange.new(0.5)
            effect.SpreadAngle = Vector2.new(360, 360)
            effect.VelocityInheritance = 0
            effect.Speed = NumberRange.new(2)
